# =============================================================================
# LensWise environment variables
# Copy to `.env.local` for local development, and set the same values in Vercel
# (Project → Settings → Environment Variables) for production.
# See docs/SUPABASE_SETUP.md and docs/VERCEL_DEPLOYMENT.md.
# =============================================================================

# --- Supabase (public — safe to expose to the browser) -----------------------
# Project URL and anon/publishable key. RLS enforces all access; the anon key
# is public by design.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (SECRET — server-side only, NEVER expose to the browser) --------
# Service-role key. Bypasses Row Level Security. Used only in Server Actions /
# Route Handlers for atomic registration and Super Admin bootstrap. Do NOT
# prefix with NEXT_PUBLIC_ and never reference it in a client component.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Platform Super Admin -----------------------------------------------------
# The single email that is promoted to platform Super Admin on first setup.
# Only this account can generate registration keys, view/disable organizations,
# etc. There is no UI to self-promote. Server-side only (never NEXT_PUBLIC_).
LENSWISE_SUPER_ADMIN_EMAIL=you@example.com

# --- Legacy proof-of-concept admin PIN (optional) -----------------------------
# The pre-SaaS Admin Pricing screen used a client-side PIN. It is superseded by
# Supabase Auth + org roles and can be left unset in production.
# NEXT_PUBLIC_DEMO_ADMIN_PIN=1234
