# Demonstration-only admin PIN for the Admin Pricing screen.
# This is NOT secure authentication. It is a simple client-side gate suitable
# only for an internal proof of concept. See README.md for details.
# If this variable is not set, the app falls back to the default PIN "1234"
# and shows a visible development-only warning in the Admin Pricing screen.
NEXT_PUBLIC_DEMO_ADMIN_PIN=1234
